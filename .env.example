OPENAI_API_KEY=your-openai-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here
DAILY_GENERATION_LIMIT=3

# Next.js app origin — the FastAPI OAuth callbacks redirect here after token exchange
WEB_BASE_URL=http://localhost:3000

# Facebook Pages integration (optional)
# Create an app at https://developers.facebook.com and enable "Facebook Login"
# Add the API server's callback URL as a Valid OAuth Redirect URI in the Facebook Login settings
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/facebook/callback   # change host to your deployed API URL in production

# LinkedIn organization posting (optional)
# Create an app at https://www.linkedin.com/developers and request the
# "Community Management API" product (w_organization_social, r_organization_admin)
# Add the API server's callback URL as an authorized redirect URL in the LinkedIn app's Auth settings
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback   # change host to your deployed API URL in production
# LINKEDIN_API_VERSION=202606                 # YYYYMM — current as of 2026-06; LinkedIn versions monthly, sunsets after ~1 year

# PostgreSQL / RAG (nekidb on AWS RDS)
# When set, RAG uses community_knowledge_embeddings instead of local FAISS
SQL_DB_HOST=neki-db.cite7dhvt5xe.us-east-1.rds.amazonaws.com
SQL_DB_NAME=nekidb
SQL_DB_USER=your-db-user
SQL_DB_PASSWORD=your-db-password
SQL_DB_PORT=5432                  # optional, default 5432
# SQL_COMMUNITY_ID=              # fallback integer communityId — normally supplied via the UI input

# LangSmith observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=content-creator-ai-agent
